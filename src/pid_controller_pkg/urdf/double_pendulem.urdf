<?xml version="1.0"?>
<robot name="sliding_double_pendulum">

  <link name="world" />

  <link name="rail_link">
    <visual>
      <geometry><box size="0.05 4.0 0.05" /></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1" /></material>
    </visual>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <joint name="world_to_rail" type="fixed">
    <parent link="world" />
    <child link="rail_link" />
    <origin xyz="0 0 2.0" />
  </joint>

  <joint name="slider_joint" type="prismatic">
    <parent link="rail_link" />
    <child link="base_link" />
    <axis xyz="0 1 0" />
    <limit lower="-1.5" upper="1.5" effort="1000.0" velocity="2.0" />
    <dynamics damping="0.0" friction="0.0" /> <!-- Zeroed for testing -->
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="0.2 0.2 0.2" /></geometry>
      <material name="blue"><color rgba="0 0 1 1" /></material>
    </visual>
    <!-- ADDED COLLISION TAG -->
    <collision>
      <geometry><box size="0.2 0.2 0.2" /></geometry>
    </collision>
    <inertial>
      <mass value="2.0" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
  </link>

  <link name="arm_link">
    <visual>
      <origin xyz="0 0 -0.25"/>
      <geometry><cylinder radius="0.02" length="0.5"/></geometry>
      <material name="green"><color rgba="0 1 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.25"/><geometry><cylinder radius="0.02" length="0.5"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.25"/><mass value="1.0"/>
      <inertia ixx="0.021" ixy="0.0" ixz="0.0" iyy="0.021" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="pendulum_joint" type="continuous">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <axis xyz="1 0 0"/> 
    <origin xyz="0 0 0" rpy="1.57 0 0"/> 
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <link name="arm_2_link">
    <visual>
      <origin xyz="0 0 -0.25"/>
      <geometry><cylinder radius="0.02" length="0.5"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.25"/><geometry><cylinder radius="0.02" length="0.5"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.25"/><mass value="1.0"/>
      <inertia ixx="0.021" ixy="0.0" ixz="0.0" iyy="0.021" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="pendulum_2_joint" type="continuous">
    <parent link="arm_link"/>
    <child link="arm_2_link"/>
    <axis xyz="1 0 0"/> 
    <origin xyz="0 0 -0.5" rpy="1.57 0 0"/> 
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <link name="target_marker">
    <visual>
      <geometry><sphere radius="0.05" /></geometry>
      <material name="yellow"><color rgba="1 1 0 0.5" /></material>
    </visual>
  </link>
  <joint name="world_to_target" type="fixed">
    <parent link="world" /><child link="target_marker" /><origin xyz="1.0 0 2.0" />
  </joint>

  <link name="sensor_frame" />
  <joint name="slider_to_sensor" type="fixed">
    <parent link="base_link" /><child link="sensor_frame" /><origin xyz="0 0.1 0" rpy="0 0 0" />
  </joint>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>slider_joint</joint_name>
      <joint_name>pendulum_joint</joint_name>
      <joint_name>pendulum_2_joint</joint_name>
      <update_rate>50</update_rate>
      <topic>/joint_states</topic>
    </plugin>

    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>slider_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
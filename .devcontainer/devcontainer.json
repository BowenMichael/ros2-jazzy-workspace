{
    "name": "ROS 2 Jazzy (AMD GPU)",
    
    // Uses the Dockerfile in the project root to build the environment
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    
    "runArgs": [
        "--net=host",                  // Use the host's network stack (important for ROS 2)
        "--device=/dev/dxg",           // Map the AMD GPU device for hardware acceleration
        "-v", "/usr/lib/wsl:/usr/lib/wsl", // Mount WSL2 drivers for GPU
        "-v", "/mnt/wslg:/mnt/wslg",       // Mount WSLg for GUI (X11/Wayland) support
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix", // Mount X Server socket for graphics
        "--name", "ros_dev_vscode"      // Set a static name for the container
    ],
    
    // Environment variables needed for WSLg graphics and audio
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "/mnt/wslg/runtime-dir",
        "PULSE_SERVER": "unix:/mnt/wslg/PulseServer"
    },
    
    "customizations": {
        "vscode": {
            // Automatically install these essential extensions inside the container
            "extensions": [
                "ms-vscode.cpptools",  // C++ IntelliSense
                "ms-python.python",     // Python IntelliSense
                "ms-iot.vscode-ros",    // ROS 2 helper tools
                "redhat.vscode-xml"     // XML/URDF formatting
            ]
        }
    },
    
    // This command runs ONCE after the container is created for the first time
    "postCreateCommand": "bash setup_workspace.sh",
    
    "remoteUser": "root"
}
